# Local overrides — copy to config.local.yaml and customize.
# This file is gitignored. Anything here is deep-merged over config.yaml.

target:
  # Point at one or more codebases to scan.
  roots:
    - ../my-app
  # Skip / scan a few extra paths on top of the built-in defaults (these are
  # appended, so node_modules, dist, tests, … stay excluded). Use include/exclude
  # instead if you want to replace the defaults entirely.
  # excludeExtra:
  #   - "**/fixtures/**"
  #   - "**/*.pb.go"

ai:
  backends:
    - claude
    - gemini
  concurrency:
    claude: 1
    gemini: 1

scan:
  # Narrow the scan to a subset of categories if you like.
  categories:
    - injection
    - broken-access-control
    - idor
    - secrets

output:
  formats:
    - json
    - markdown
    - sarif
